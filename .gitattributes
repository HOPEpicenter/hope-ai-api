# Default: let Git normalize text files
* text=auto

# Force LF for source + scripts (cross-platform consistency)
*.ts  text eol=lf
*.tsx text eol=lf
*.js  text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.md  text eol=lf
*.ps1 text eol=lf
*.sh  text eol=lf

# Common binary types (never normalize)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.pdf binary
* text=auto
