{
  "scriptFile": "../dist/functions/getIntegrationSummary/index.js",
  "entryPoint": "getIntegrationSummary",
  "bindings": [
    {
      "authLevel": "anonymous",
      "type": "httpTrigger",
      "direction": "in",
      "name": "req",
      "methods": [ "get" ],
      "route": "integration/summary"
    },
    {
      "type": "http",
      "direction": "out",
      "name": "$return"
    }
  ]
}
